{
  "version": 8,
  "name": "Zairn Wafuu",
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "https://tiles.openfreemap.org/planet"
    },
    "terrain-dem": {
      "type": "raster-dem",
      "tiles": [
        "https://s3.amazonaws.com/elevation-tiles-prod/terrarium/{z}/{x}/{y}.png"
      ],
      "tileSize": 256,
      "encoding": "terrarium",
      "maxzoom": 15
    }
  },
  "glyphs": "https://otanl.github.io/zairn-glyphs/{fontstack}/{range}.pbf",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#f5f0e8"
      }
    },
    {
      "id": "hillshade",
      "type": "hillshade",
      "source": "terrain-dem",
      "paint": {
        "hillshade-shadow-color": "#8a7860",
        "hillshade-highlight-color": "#faf6ee",
        "hillshade-accent-color": "#d4c8b0",
        "hillshade-illumination-direction": 315,
        "hillshade-exaggeration": 0.5
      }
    },
